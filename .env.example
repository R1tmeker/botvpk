# Environment example for botvpk
# Path where app will be deployed on server
APP_PATH=/opt/botvpk
BOT_TOKEN=put_bot_token_here
POSTGRES_DB=vpk_zvezda
POSTGRES_USER=vpk
POSTGRES_PASSWORD=change_me_db_password
DATABASE_URL=postgresql+asyncpg://vpk:change_me_db_password@postgres:5432/vpk_zvezda
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
TZ=Asia/Novosibirsk
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,https://example.com
MINI_APP_URL=https://example.com/
BOT_USERNAME=
UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=20
REDIS_URL=redis://redis:6379/0
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
RELEASE_VERSION=local
BOT_HEARTBEAT_PATH=/tmp/botvpk-bot.heartbeat
VK_BOT_HEARTBEAT_PATH=/tmp/botvpk-vk-bot.heartbeat
BIRTHDAYS_CHAT_ID=
BIRTHDAYS_THREAD_ID=
BIRTHDAYS_TIME=09:00
DEFAULT_POLL_CHAT_ID=
LEAP_POLICY=28
DRYRUN=true
SUPER_ADMIN_ID=123456789
# Alias from the TZ is also supported:
# SUPER_ADMIN_TG_ID=123456789

# ── VK channel (optional, disabled by default) ──
# When enabled, members can link their VK account (code issued in the Mini App)
# and receive push notifications in VK. The site login stays password-based.
VK_BOT_ENABLED=false
VK_GROUP_TOKEN=
VK_GROUP_ID=
# Public link to the VK community/bot (shown as "Open VK bot" button), e.g. https://vk.me/your_group
VK_BOT_URL=
# Public website URL used by the VK bot's "Open site" button (falls back to MINI_APP_URL)
SITE_URL=

# ── Web Push (optional; generate VAPID keys before enabling) ──
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUB=mailto:admin@example.com
