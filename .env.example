# Environment example for botvpk
TELEGRAM_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_YOUR_TELEGRAM_CHAT_ID
# Path where app will be deployed on server
APP_PATH=/opt/botvpk
# Other app-specific settings
DATABASE_URL=sqlite:///data/db.sqlite3
BOT_TOKEN=put_bot_token_here
POSTGRES_DB=vpk_zvezda
POSTGRES_USER=vpk
POSTGRES_PASSWORD=change_me_db_password
DATABASE_URL=postgresql+asyncpg://vpk:change_me_db_password@postgres:5432/vpk_zvezda
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
TZ=Asia/Novosibirsk
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,https://example.com
MINI_APP_URL=https://example.com/
UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=20
BIRTHDAYS_CHAT_ID=
BIRTHDAYS_THREAD_ID=
BIRTHDAYS_TIME=09:00
DEFAULT_POLL_CHAT_ID=
LEAP_POLICY=28
DRYRUN=true
SUPER_ADMIN_ID=123456789
# Alias from the TZ is also supported:
# SUPER_ADMIN_TG_ID=123456789
